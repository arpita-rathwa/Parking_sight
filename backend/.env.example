# Database
POSTGRES_DB=parksight
POSTGRES_USER=parksight
POSTGRES_PASSWORD=parksight
DATABASE_URL=postgresql+psycopg2://parksight:parksight@postgres:5432/parksight

# Redis
REDIS_URL=redis://redis:6379/0

# Kafka
KAFKA_BOOTSTRAP_SERVERS=kafka:9092

# Security — generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS — comma-separated origins, or * for development
CORS_ORIGINS=*

# Sentry (optional)
SENTRY_DSN=

# AWS (optional for S3/CloudWatch)
AWS_REGION=ap-south-1
S3_BUCKET=parksight-media
CLOUDWATCH_LOG_GROUP=parksight

# Rate limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60

# ML
DETECTION_CONFIDENCE_THRESHOLD=0.5
MODEL_PATH=yolov8n.pt
